{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/enforce_init_session.py"}]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/enforce_track_read.py"}]
      },
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/enforce_track_search.py"}]
      }
    ],
    "Stop": [
      {
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/enforce_stop.py"}]
      }
    ]
  }
}
